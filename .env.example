# MongoDB Connection (Atlas or local)
# Example Atlas format with DB name: mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?appName=<cluster-name>
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/billingSystem?appName=<cluster-name>

# JWT Secret (generate a secure random string for production)
JWT_SECRET=your_secure_jwt_secret_key_here

# Admin User Credentials
ADMIN_ID=admin
ADMIN_PASSWORD=admin123
ADMIN_USERNAME=Administrator

# Frontend Origin (CORS)
FRONTEND_URL=https://billingsystem1.onrender.com

# Server Port (default: 5000)
PORT=5000